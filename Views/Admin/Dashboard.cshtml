@model dienlanh.Models.AdminStatisticsViewModel

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar Menu -->
        <div class="col-md-3 col-lg-2 bg-light border-end">
            <div class="admin-menu">
                <h5 class="menu-title p-3 border-bottom">
                    Bảng điều khiển
                </h5>

                <div class="menu-section">
                    <h6 class="menu-subtitle">Thống kê theo thời gian</h6>
                    <nav class="nav flex-column">
                        <a class="nav-link @(Model.SelectedPeriod == "all" ? "active" : "")" 
                           href="@Url.Action("Dashboard", "Admin", new { period = "all" })">
                            Tổng hợp
                        </a>
                        <a class="nav-link @(Model.SelectedPeriod == "day" ? "active" : "")" 
                           href="@Url.Action("Dashboard", "Admin", new { period = "day" })">
                            Hôm nay
                        </a>
                        <a class="nav-link @(Model.SelectedPeriod == "month" ? "active" : "")" 
                           href="@Url.Action("Dashboard", "Admin", new { period = "month" })">
                            Tháng này
                        </a>
                        <a class="nav-link @(Model.SelectedPeriod == "year" ? "active" : "")" 
                           href="@Url.Action("Dashboard", "Admin", new { period = "year" })">
                            Năm nay
                        </a>
                    </nav>
                </div>

                <div class="menu-section border-top">
                    <h6 class="menu-subtitle">Quản lý</h6>
                    <nav class="nav flex-column">
                        <a class="nav-link" href="@Url.Action("Requests", "Admin")">
                            Danh sách yêu cầu
                        </a>
                        <a class="nav-link" href="@Url.Action("Staff", "Admin")">
                            Nhân viên
                        </a>
                        <a class="nav-link" href="@Url.Action("Reports", "Admin")">
                            Báo cáo lỗi
                        </a>
                        <a class="nav-link" href="@Url.Action("Statistics", "Admin")">
                            Thống kê chi tiết
                        </a>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9 col-lg-10">
            <div class="content-area p-4">
                <h2 class="mb-1">Bảng điều khiển quản trị</h2>
                <p class="text-muted mb-4">
                    @if (Model.SelectedPeriod == "day")
                    {
                        <span>Thống kê cho <strong>hôm nay</strong></span>
                    }
                    else if (Model.SelectedPeriod == "month")
                    {
                        <span>Thống kê cho <strong>tháng này</strong></span>
                    }
                    else if (Model.SelectedPeriod == "year")
                    {
                        <span>Thống kê cho <strong>năm nay</strong></span>
                    }
                    else
                    {
                        <span>Thống kê <strong>tổng hợp</strong></span>
                    }
                </p>

                <!-- Statistics Cards -->
                <div class="row g-3 mb-4">
                    @if (Model.SelectedPeriod == "all")
                    {
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Tổng yêu cầu</div>
                                        <div class="stat-value">@Model.TotalRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Chờ xử lý</div>
                                        <div class="stat-value">@Model.PendingRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Hoàn thành</div>
                                        <div class="stat-value">@Model.CompletedRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Doanh thu</div>
                                        <div class="stat-value">@Model.TotalRevenue.ToString("N0")đ</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else if (Model.SelectedPeriod == "day")
                    {
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Yêu cầu</div>
                                        <div class="stat-value">@Model.TodayRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Hoàn thành</div>
                                        <div class="stat-value">@Model.TodayCompletedRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Doanh thu</div>
                                        <div class="stat-value">@Model.TodayRevenue.ToString("N0")đ</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else if (Model.SelectedPeriod == "month")
                    {
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Yêu cầu</div>
                                        <div class="stat-value">@Model.MonthRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Hoàn thành</div>
                                        <div class="stat-value">@Model.MonthCompletedRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Doanh thu</div>
                                        <div class="stat-value">@Model.MonthRevenue.ToString("N0")đ</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else if (Model.SelectedPeriod == "year")
                    {
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Yêu cầu</div>
                                        <div class="stat-value">@Model.YearRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Hoàn thành</div>
                                        <div class="stat-value">@Model.YearCompletedRequests</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm stat-card">
                                <div class="card-body">
                                    <div class="stat-content">
                                        <div class="stat-label">Doanh thu</div>
                                        <div class="stat-value">@Model.YearRevenue.ToString("N0")đ</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (Model.SelectedPeriod == "all")
                {
                    <!-- Additional info for all period -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="card shadow-sm border-0">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        Tài khoản hệ thống
                                    </h5>
                                    <div class="info-row">
                                        <span class="info-label">Khách hàng:</span>
                                        <span class="info-value fw-bold">@Model.TotalCustomers</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Kỹ thuật viên:</span>
                                        <span class="info-value fw-bold">@Model.TotalTechnicians</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card shadow-sm border-0">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        Thanh toán
                                    </h5>
                                    <div class="info-row">
                                        <span class="info-label">Yêu cầu đã thanh toán:</span>
                                        <span class="info-value fw-bold">@Model.PaidRequests</span>
                                    </div>
                                    <div class="mt-2">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Statistics", "Admin")">
                                            Xem chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .admin-menu {
        min-height: 100vh;
        background-color: #f8f9fa;
    }

    .menu-title {
        font-weight: 700;
        color: #2c3e50;
        font-size: 16px;
    }

    .menu-section {
        padding: 15px 0;
    }

    .menu-subtitle {
        padding: 0 15px 10px 15px;
        font-size: 12px;
        font-weight: 600;
        color: #7f8c8d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .admin-menu .nav-link {
        padding: 10px 20px;
        color: #555;
        text-decoration: none;
        transition: all 0.3s ease;
        border-left: 3px solid transparent;
        font-size: 14px;
    }

    .admin-menu .nav-link:hover {
        background-color: #e9ecef;
        color: #007bff;
        border-left-color: #007bff;
    }

    .admin-menu .nav-link.active {
        background-color: #e7f3ff;
        color: #007bff;
        border-left-color: #007bff;
        font-weight: 600;
    }

    .stat-card {
        transition: all 0.3s ease;
        border-radius: 8px;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
    }

    .stat-card .card-body {
        padding: 20px;
    }

    .stat-content {
        flex: 1;
    }

    .stat-label {
        font-size: 12px;
        color: #6c757d;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: #2c3e50;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #e9ecef;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: #6c757d;
        font-size: 14px;
    }

    .info-value {
        color: #2c3e50;
        font-size: 14px;
    }

    .content-area {
        background-color: #fff;
    }

    @@media (max-width: 768px) {
        .admin-menu {
            min-height: auto;
            margin-bottom: 20px;
            border-radius: 8px;
        }

        .stat-card .card-body {
            text-align: center;
        }
    }
</style>
