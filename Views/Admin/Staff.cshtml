@model List<dienlanh.Models.User>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Quản lý nhân viên</h2>
    <a asp-action="CreateStaff" class="btn btn-primary">+ Thêm nhân viên</a>
</div>

@if (TempData["StaffSuccess"] != null)
{
    <div class="alert alert-success">@TempData["StaffSuccess"]</div>
}
@if (TempData["StaffError"] != null)
{
    <div class="alert alert-danger">@TempData["StaffError"]</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Họ tên</th>
                        <th>Số điện thoại</th>
                        <th>Chuyên môn</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Chưa có nhân viên nào.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Name) ? "(Chưa cập nhật)" : item.Name)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Phone) ? "-" : item.Phone)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Specializations) ? "-" : item.Specializations)</td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="badge @(item.Role == "admin" ? "bg-danger" : "bg-info text-dark")">
                                        @item.Role
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="EditStaff" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                                    <form asp-action="DeleteStaff" method="post" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa nhân viên này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
