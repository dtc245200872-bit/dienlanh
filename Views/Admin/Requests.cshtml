@model List<dienlanh.Models.RepairRequest>

<div class="page-header">
    <div>
        <h2 class="page-title">Danh sách yêu cầu</h2>
        <p class="page-subtitle">Kiểm duyệt yêu cầu và phân công kỹ thuật viên theo trạng thái xử lý.</p>
    </div>
</div>

<div class="app-table-wrap">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Thiết bị</th>
                <th>Sự cố</th>
                <th>Lịch hẹn</th>
                <th>Trạng thái</th>
                <th>Duyệt yêu cầu</th>
                <th>Phân công</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DeviceType</td>
                    <td>@item.Issue</td>
                    <td>@(item.PreferredVisitAt.HasValue ? item.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")</td>
                    <td><span class="badge bg-secondary">@item.Status</span></td>
                    <td>
                        @if (item.Status == "Chờ xử lý")
                        {
                            <form method="post" action="/Admin/Review" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="decision" value="approve" />
                                <button type="submit" class="btn btn-sm btn-primary">Duyệt</button>
                            </form>
                            <form method="post" action="/Admin/Review" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="decision" value="reject" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Từ chối</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">Đã xử lý</span>
                        }
                    </td>
                    <td>
                        @if (item.Status == "Đã duyệt")
                        {
                            <a href="/Admin/Assign/@item.Id" class="btn btn-sm btn-primary">Phân công</a>
                        }
                        else if (item.Status == "Đã phân công" || item.Status == "Đang sửa" || item.Status == "Hoàn thành" || item.Status == "Đã thanh toán")
                        {
                            <span class="text-success">Đã phân công</span>
                        }
                        else
                        {
                            <span class="text-muted">Chưa thể phân công</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>