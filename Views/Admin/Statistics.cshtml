@model dienlanh.Models.AdminStatisticsViewModel

<h2 class="mb-4">Thống kê hệ thống</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted">Tổng yêu cầu</div>
                <div class="fs-4 fw-bold">@Model.TotalRequests</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted">Đã thanh toán</div>
                <div class="fs-4 fw-bold text-success">@Model.PaidRequests</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted">Khách hàng</div>
                <div class="fs-4 fw-bold">@Model.TotalCustomers</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted">Doanh thu</div>
                <div class="fs-4 fw-bold text-primary">@Model.TotalRevenue.ToString("N0")đ</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="mb-3">Thống kê theo thiết bị</h5>
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Thiết bị</th>
                            <th class="text-end">Số yêu cầu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.DeviceBreakdown.Any())
                        {
                            <tr>
                                <td colspan="2" class="text-center text-muted">Chưa có dữ liệu</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.DeviceBreakdown)
                            {
                                <tr>
                                    <td>@item.DeviceType</td>
                                    <td class="text-end">@item.Count</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="mb-3">Thống kê theo trạng thái</h5>
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Trạng thái</th>
                            <th class="text-end">Số lượng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.StatusBreakdown.Any())
                        {
                            <tr>
                                <td colspan="2" class="text-center text-muted">Chưa có dữ liệu</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.StatusBreakdown)
                            {
                                <tr>
                                    <td>@item.Status</td>
                                    <td class="text-end">@item.Count</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
