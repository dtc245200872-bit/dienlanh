@model dienlanh.Models.AdminStatisticsViewModel

<div class="page-header">
    <div>
        <h2 class="page-title">Thống kê hệ thống</h2>
        <p class="page-subtitle">Theo dõi tình hình yêu cầu, doanh thu và hiệu suất vận hành.</p>
    </div>
</div>

<div class="stats-header-card mb-4">
    <div class="stats-container">
        <div class="stat-item">
            <div class="stat-label">Tổng yêu cầu</div>
            <div class="stat-value">@Model.TotalRequests</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-label">Đã thanh toán</div>
            <div class="stat-value stat-success">@Model.PaidRequests</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-label">Khách hàng</div>
            <div class="stat-value">@Model.TotalCustomers</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-label">Doanh thu</div>
            <div class="stat-value stat-primary">@Model.TotalRevenue.ToString("N0")đ</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="section-card">
            <div class="card-body">
                <h5 class="mb-3">Thống kê theo thiết bị</h5>
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Thiết bị</th>
                            <th class="text-end">Số yêu cầu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.DeviceBreakdown.Any())
                        {
                            <tr>
                                <td colspan="2" class="empty-state">Chưa có dữ liệu</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.DeviceBreakdown)
                            {
                                <tr>
                                    <td>@item.DeviceType</td>
                                    <td class="text-end">@item.Count</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="section-card">
            <div class="card-body">
                <h5 class="mb-3">Thống kê theo trạng thái</h5>
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Trạng thái</th>
                            <th class="text-end">Số lượng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.StatusBreakdown.Any())
                        {
                            <tr>
                                <td colspan="2" class="empty-state">Chưa có dữ liệu</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.StatusBreakdown)
                            {
                                <tr>
                                    <td>@item.Status</td>
                                    <td class="text-end">@item.Count</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .page-header {
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 5px;
    }

    .page-subtitle {
        color: #7f8c8d;
        font-size: 14px;
        margin-bottom: 0;
    }

    .stats-header-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        border: 1px solid #e9ecef;
        overflow: hidden;
    }

    .stats-container {
        display: flex;
        align-items: center;
        justify-content: space-around;
        padding: 24px;
        gap: 20px;
    }

    .stat-item {
        flex: 1;
        text-align: center;
        padding: 0 15px;
    }

    .stat-label {
        font-size: 13px;
        font-weight: 600;
        color: #7f8c8d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
    }

    .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: #2c3e50;
    }

    .stat-value.stat-success {
        color: #27ae60;
    }

    .stat-value.stat-primary {
        color: #007bff;
    }

    .stat-divider {
        width: 1px;
        height: 60px;
        background-color: #e9ecef;
        margin: 0 10px;
    }

    .section-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        border: 1px solid #e9ecef;
        transition: all 0.3s ease;
    }

    .section-card:hover {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
        border-color: #dee2e6;
    }

    .card-body {
        padding: 24px;
    }

    .table {
        margin-bottom: 0;
    }

    .table thead {
        background: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .table thead th {
        font-weight: 600;
        color: #2c3e50;
        padding: 12px;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: background-color 0.2s ease;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }

    .table tbody td {
        padding: 12px;
        color: #555;
    }

    .empty-state {
        text-align: center;
        color: #95a5a6;
        font-style: italic;
        padding: 30px !important;
    }

    @@media (max-width: 768px) {
        .stats-container {
            flex-wrap: wrap;
            padding: 16px;
        }

        .stat-item {
            flex: 1 1 45%;
            padding: 10px;
        }

        .stat-divider {
            display: none;
        }

        .stat-value {
            font-size: 24px;
        }

        .stat-label {
            font-size: 12px;
        }

        .page-title {
            font-size: 24px;
        }
    }

    @@media (max-width: 576px) {
        .stats-container {
            flex-wrap: wrap;
            padding: 12px;
            gap: 10px;
        }

        .stat-item {
            flex: 1 1 100%;
            padding: 8px;
        }

        .stat-value {
            font-size: 20px;
        }

        .page-title {
            font-size: 20px;
        }
    }
</style>
