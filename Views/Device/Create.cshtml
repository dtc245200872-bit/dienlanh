@model dienlanh.Models.Device

<h2 class="mb-3">Thêm thiết bị</h2>

<form method="post" class="card p-4 shadow-sm">
    <div class="mb-3">
        <label class="form-label">Tên thiết bị</label>
        <input class="form-control" name="Name" value="@Model?.Name" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Mô tả</label>
        <textarea class="form-control" name="Description" rows="3">@Model?.Description</textarea>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-success">Lưu</button>
        <a class="btn btn-outline-secondary" href="/Device/Index">Quay lại</a>
    </div>
</form>
