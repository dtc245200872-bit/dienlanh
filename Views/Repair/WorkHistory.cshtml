@model List<dienlanh.Models.RepairRequest>
@{
    ViewData["Title"] = "Lịch sử công việc";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="page-title">
                <i class="fas fa-history"></i> Lịch sử công việc
            </h2>
            <p class="text-muted">Xem tất cả công việc bạn đã thực hiện</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-md-12">
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    <i class="fas fa-info-circle"></i>
                    <strong>Chưa có lịch sử công việc</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        </div>
    }
    else
    {
        @foreach (var job in Model.OrderByDescending(j => j.PreferredVisitAt))
        {
            <div class="row mb-3">
                <div class="col-md-12">
                    <div class="history-table-container">
                        <div class="job-card-header">
                            <div class="job-header-info">
                                <h5 class="job-title">
                                    <i class="fas fa-tools"></i> @job.DeviceType
                                </h5>
                                <p class="job-subtitle">@job.Issue</p>
                            </div>
                            <div class="job-header-status">
                                @switch (job.Status)
                                {
                                    case "Đang sửa":
                                        <span class="badge bg-primary">Đang thực hiện</span>
                                        break;
                                    case "Hoàn thành":
                                        <span class="badge bg-success">Hoàn thành</span>
                                        break;
                                    case "Đã thanh toán":
                                        <span class="badge bg-info">Đã thanh toán</span>
                                        break;
                                    case "Đã báo lỗi":
                                        <span class="badge bg-danger">Báo lỗi</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@job.Status</span>
                                        break;
                                }
                            </div>
                        </div>
                        <table class="table table-hover history-table mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 25%;">Địa chỉ</th>
                                    <th style="width: 25%;">Lịch hẹn</th>
                                    <th style="width: 25%;">Đánh giá</th>
                                    <th style="width: 25%;">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <span class="address-text">@job.Address</span>
                                    </td>
                                    <td>
                                        <span class="date-text">
                                            @(job.PreferredVisitAt.HasValue ? job.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                                        </span>
                                    </td>
                                    <td>
                                        @if (job.TechnicianRating.HasValue)
                                        {
                                            <div class="rating-stars">
                                                <span class="rating-value">@job.TechnicianRating / 5</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(job.TechnicianRatingComment))
                                            {
                                                <small class="text-muted d-block">@job.TechnicianRatingComment</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted">Chưa đánh giá</span>
                                        }
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#detailModal@job.Id">
                                            <i class="fas fa-eye"></i> Xem
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Modals Container -->
@if (Model.Any())
{
    @foreach (var job in Model.OrderByDescending(j => j.PreferredVisitAt))
    {
        <!-- Detail Modal -->
        <div class="modal fade"
             id="detailModal@job.Id"
             tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-light">
                        <h5 class="modal-title">Chi tiết công việc</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6">
                                <dl class="row mb-0">
                                    <dt class="col-sm-5">Thiết bị:</dt>
                                    <dd class="col-sm-7">@job.DeviceType</dd>

                                    <dt class="col-sm-5">Sự cố:</dt>
                                    <dd class="col-sm-7">@job.Issue</dd>

                                    <dt class="col-sm-5">Địa chỉ:</dt>
                                    <dd class="col-sm-7">@job.Address</dd>

                                    <dt class="col-sm-5">Số điện thoại:</dt>
                                    <dd class="col-sm-7">@job.Phone</dd>
                                </dl>
                            </div>
                            <div class="col-md-6">
                                <dl class="row mb-0">
                                    <dt class="col-sm-5">Lịch hẹn:</dt>
                                    <dd class="col-sm-7">
                                        @(job.PreferredVisitAt.HasValue ? job.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                                    </dd>

                                    <dt class="col-sm-5">Trạng thái:</dt>
                                    <dd class="col-sm-7">
                                        <span class="badge bg-secondary">@job.Status</span>
                                    </dd>

                                    <dt class="col-sm-5">Linh kiện:</dt>
                                    <dd class="col-sm-7">
                                        @(string.IsNullOrEmpty(job.ReplacedParts) ? "-" : job.ReplacedParts)
                                    </dd>

                                    <dt class="col-sm-5">Chi phí:</dt>
                                    <dd class="col-sm-7">
                                        @(job.FinalAmount.HasValue ? job.FinalAmount.Value.ToString("N0") + " đ" : "-")
                                    </dd>
                                </dl>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(job.ImagePath))
                        {
                            <div class="mt-3">
                                <p><strong>Hình ảnh:</strong></p>
                                <img src="@job.ImagePath" class="img-fluid rounded" style="max-height: 300px; width: 100%; object-fit: cover;" />
                            </div>
                        }

                        @if (job.TechnicianRating.HasValue)
                        {
                            <div class="mt-3 p-3 bg-light rounded">
                                <strong>Đánh giá từ khách hàng:</strong>
                                <div class="mt-2">
                                    <div class="rating-stars mb-2">
                                        <span class="rating-value">@job.TechnicianRating / 5</span>
                                    </div>
                                    <p>@job.TechnicianRatingComment</p>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

<style>
    .page-title {
        color: #2c3e50;
        font-weight: 700;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-title i {
        font-size: 28px;
        color: #007bff;
    }

    .history-table-container {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        border: 1px solid #e9ecef;
        transition: all 0.3s ease;
    }

    .history-table-container:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    }

    .job-card-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #dee2e6;
    }

    .job-header-info {
        flex: 1;
    }

    .job-title {
        font-size: 16px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .job-title i {
        color: #007bff;
        font-size: 18px;
    }

    .job-subtitle {
        font-size: 13px;
        color: #7f8c8d;
        margin-bottom: 0;
    }

    .job-header-status {
        margin-left: 20px;
    }

    .history-table {
        margin-bottom: 0;
    }

    .history-table thead {
        background: #f8f9fa;
        font-weight: 600;
        color: #2c3e50;
    }

    .history-table thead th {
        border-bottom: 2px solid #dee2e6;
        vertical-align: middle;
        padding: 14px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .history-table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid #e9ecef;
    }

    .history-table tbody tr:hover {
        background-color: #f8f9fa;
        box-shadow: inset 0 0 0 1px #dee2e6;
    }

    .history-table tbody td {
        padding: 14px;
        vertical-align: middle;
    }

    .issue-text,
    .address-text,
    .date-text {
        color: #555;
        font-size: 14px;
        line-height: 1.4;
    }

    .rating-stars {
        display: flex;
        gap: 4px;
        align-items: center;
    }

    .rating-value {
        font-size: 14px;
        font-weight: 600;
        color: #2c3e50;
    }

    .btn-outline-primary {
        border-color: #007bff;
        color: #007bff;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .btn-outline-primary:hover {
        background-color: #007bff;
        border-color: #007bff;
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0, 123, 255, 0.3);
    }

    .btn-outline-primary i {
        margin-right: 4px;
    }

    .badge {
        padding: 6px 10px;
        font-size: 12px;
        font-weight: 500;
        border-radius: 6px;
    }

    .modal-header {
        border-bottom: 2px solid #e9ecef;
    }

    .modal-content {
        border: 1px solid #dee2e6;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
    }

    @@media (max-width: 992px) {
        .history-table {
            font-size: 13px;
        }

        .history-table th,
        .history-table td {
            padding: 10px;
        }

        .job-card-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .job-header-status {
            margin-left: 0;
            margin-top: 8px;
        }
    }

    @@media (max-width: 768px) {
        .page-title {
            font-size: 20px;
        }

        .page-title i {
            font-size: 24px;
        }

        .history-table-container {
            overflow-x: auto;
        }

        .history-table {
            font-size: 12px;
            min-width: 600px;
        }

        .history-table th,
        .history-table td {
            padding: 8px;
        }

        .job-card-header {
            padding: 12px 15px;
        }

        .job-title {
            font-size: 14px;
        }

        .job-subtitle {
            font-size: 12px;
        }
    }

    @@media (max-width: 576px) {
        .container-fluid {
            padding: 10px;
        }

        .page-title {
            font-size: 18px;
        }

        .history-table {
            font-size: 11px;
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
            font-size: 11px;
        }
    }
</style>
