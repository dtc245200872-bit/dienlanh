@model List<dienlanh.Models.RepairRequest>
@{
    ViewData["Title"] = "Công việc được phân công";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="page-title">
                Công việc được phân công
            </h2>
            <p class="text-muted">Danh sách tất cả công việc chờ bạn nhận</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-md-12">
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    <strong>Không có công việc chờ nhận</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-12">
                <div class="tasks-container">
                    @foreach (var task in Model.OrderBy(t => t.PreferredVisitAt))
                    {
                        <div class="task-item">
                            <div class="task-priority">
                                @if (task.PreferredVisitAt.HasValue && task.PreferredVisitAt.Value <= DateTime.Now.AddHours(2))
                                {
                                    <span class="priority-badge priority-urgent">Gấp</span>
                                }
                                else
                                {
                                    <span class="priority-badge priority-normal">Bình thường</span>
                                }
                            </div>

                            <div class="task-header">
                                <div class="task-title">
                                    <h5>@task.DeviceType</h5>
                                    <p class="task-issue">@task.Issue</p>
                                </div>
                                <div class="task-status">
                                    <span class="badge bg-warning text-dark">
                                        Chuẩn bị bắt đầu
                                    </span>
                                </div>
                            </div>

                            <div class="task-details">
                                <div class="detail-item">
                                    <strong>Địa chỉ:</strong>
                                    <span>@task.Address</span>
                                </div>
                                <div class="detail-item">
                                    <strong>Lịch hẹn:</strong>
                                    <span>@(task.PreferredVisitAt.HasValue ? task.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa xác định")</span>
                                </div>
                                <div class="detail-item">
                                    <strong>Số điện thoại:</strong>
                                    <span>@task.Phone</span>
                                </div>
                                <div class="detail-item">
                                    <strong>Email:</strong>
                                    <span>@task.Email</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(task.ImagePath))
                            {
                                <div class="task-image">
                                    <img src="@task.ImagePath" alt="Device image" />
                                </div>
                            }

                            <div class="task-actions">
                                <a href="/Repair/UpdateStatus?id=@task.Id&status=Đang sửa" class="btn btn-primary btn-lg">
                                    Nhận việc này
                                </a>
                                <button type="button" class="btn btn-outline-secondary btn-lg" data-bs-toggle="modal" data-bs-target="#detailModal@task.Id">
                                    Xem chi tiết
                                </button>
                            </div>
                        </div>

                        <!-- Detail Modal -->
                        <div class="modal fade" id="detailModal@task.Id" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Chi tiết công việc</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <dl class="row">
                                            <dt class="col-sm-4">Thiết bị:</dt>
                                            <dd class="col-sm-8">@task.DeviceType</dd>

                                            <dt class="col-sm-4">Sự cố:</dt>
                                            <dd class="col-sm-8">@task.Issue</dd>

                                            <dt class="col-sm-4">Địa chỉ:</dt>
                                            <dd class="col-sm-8">@task.Address</dd>

                                            <dt class="col-sm-4">Số điện thoại:</dt>
                                            <dd class="col-sm-8">@task.Phone</dd>

                                            <dt class="col-sm-4">Email:</dt>
                                            <dd class="col-sm-8">@task.Email</dd>

                                            <dt class="col-sm-4">Lịch hẹn:</dt>
                                            <dd class="col-sm-8">
                                                @(task.PreferredVisitAt.HasValue ? task.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa xác định")
                                            </dd>

                                            <dt class="col-sm-4">Trạng thái:</dt>
                                            <dd class="col-sm-8">
                                                <span class="badge bg-warning text-dark">@task.Status</span>
                                            </dd>
                                        </dl>

                                        @if (!string.IsNullOrEmpty(task.ImagePath))
                                        {
                                            <div class="mt-3">
                                                <p><strong>Hình ảnh thiết bị:</strong></p>
                                                <img src="@task.ImagePath" class="img-fluid rounded" style="max-height: 300px; width: 100%; object-fit: cover;" />
                                            </div>
                                        }
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                        <a href="/Repair/UpdateStatus?id=@task.Id&status=Đang sửa" class="btn btn-primary">
                                            Nhận việc
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    .page-title {
        color: #2c3e50;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .tasks-container {
        display: grid;
        gap: 20px;
    }

    .task-item {
        background: white;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        border-left: 4px solid #667eea;
    }

    .task-item:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
    }

    .task-priority {
        margin-bottom: 12px;
    }

    .priority-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .priority-urgent {
        background: #ffe5e5;
        color: #c5192d;
    }

    .priority-normal {
        background: #e7f3ff;
        color: #004085;
    }

    .task-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 15px;
        padding-bottom: 15px;
        border-bottom: 1px solid #ecf0f1;
    }

    .task-title h5 {
        color: #2c3e50;
        font-weight: 600;
        margin: 0;
        font-size: 18px;
    }

    .task-issue {
        color: #555;
        margin: 5px 0 0 0;
        font-size: 14px;
    }

    .task-status {
        flex-shrink: 0;
        margin-left: 20px;
    }

    .task-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-bottom: 15px;
        padding: 15px 0;
        border-bottom: 1px solid #ecf0f1;
    }

    .detail-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        color: #555;
    }

    .task-image {
        margin-bottom: 15px;
        border-radius: 8px;
        overflow: hidden;
    }

    .task-image img {
        width: 100%;
        height: auto;
        max-height: 300px;
        object-fit: cover;
        display: block;
    }

    .task-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .task-actions .btn {
        flex: 1;
        min-width: 200px;
    }

    @@media (max-width: 768px) {
        .task-header {
            flex-direction: column;
            gap: 10px;
        }

        .task-status {
            margin-left: 0;
        }

        .task-details {
            grid-template-columns: 1fr;
        }

        .task-actions {
            flex-direction: column;
        }

        .task-actions .btn {
            width: 100%;
        }
    }
</style>
