@model List<dienlanh.Models.RepairRequest>
@{
    var history = ViewBag.JobHistory as List<dienlanh.Models.RepairRequest> ?? new List<dienlanh.Models.RepairRequest>();
}

<div class="page-header">
    <div>
        <h2 class="page-title">Công việc được phân công</h2>
        <p class="page-subtitle">Theo dõi công việc đang chờ xử lý và lịch sử hoàn thành.</p>
    </div>
</div>

<div class="app-table-wrap">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Thiết bị</th>
            <th>Sự cố</th>
            <th>Địa chỉ</th>
            <th>Lịch hẹn</th>
            <th>Trạng thái</th>
            <th>Ảnh</th>
            <th>Hành động</th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted">Chưa có công việc chờ nhận.</td>
            </tr>
        }
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DeviceType</td>
                <td>@item.Issue</td>
                <td>@item.Address</td>
                <td>@(item.PreferredVisitAt.HasValue ? item.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")</td>

                <td>
                    @if (item.Status == "Chờ xử lý")
                    {
                        <span class="badge bg-secondary">Chờ xử lý</span>
                    }
                    else if (item.Status == "Đã phân công")
                    {
                        <span class="badge bg-warning text-dark">Chuẩn bị bắt đầu</span>
                    }
                    else if (item.Status == "Đang sửa")
                    {
                        <span class="badge bg-primary">Đang thực hiện</span>
                    }
                    else if (item.Status == "Hoàn thành")
                    {
                        <span class="badge bg-success">Hoàn thành</span>
                    }
                    else
                    {
                        <span class="badge bg-dark">@item.Status</span>
                    }
                </td>
                <td>
                    @if (item.ImagePath != null)
                    {
                        <img src="@item.ImagePath" width="100" style="border-radius:10px;" />
                    }
                </td>

                <td>
                    <a href="/Repair/UpdateStatus?id=@item.Id&status=Đang sửa"
                       class="btn btn-primary btn-sm">
                        Nhận việc
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

<div class="page-header mt-4">
    <div>
        <h2 class="page-title">Lịch sử công việc của tôi</h2>
    </div>
</div>
<div class="app-table-wrap">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Thiết bị</th>
            <th>Sự cố</th>
            <th>Địa chỉ</th>
            <th>Lịch hẹn</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (!history.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Chưa có lịch sử công việc.</td>
            </tr>
        }
        @foreach (var item in history)
        {
            <tr>
                <td>@item.DeviceType</td>
                <td>@item.Issue</td>
                <td>@item.Address</td>
                <td>@(item.PreferredVisitAt.HasValue ? item.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")</td>
                <td>
                    @if (item.Status == "Đang sửa")
                    {
                        <span class="badge bg-primary">Đang thực hiện</span>
                    }
                    else if (item.Status == "Hoàn thành")
                    {
                        <span class="badge bg-success">Hoàn thành</span>
                    }
                    else if (item.Status == "Đã thanh toán")
                    {
                        <span class="badge bg-info text-dark">Đã thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-dark">@item.Status</span>
                    }
                </td>
                <td>
                    @if (item.Status == "Đang sửa")
                    {
                        <a href="/Repair/Complete?id=@item.Id"
                           class="btn btn-success btn-sm">
                            Chọn linh kiện & Hoàn thành
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">---</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
</div>