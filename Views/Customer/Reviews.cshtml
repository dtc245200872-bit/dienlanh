@model List<dienlanh.Models.RepairRequest>

<div class="page-header">
    <div>
        <h2 class="page-title">Đánh giá kỹ thuật viên</h2>
        <p class="page-subtitle">Xem lịch sử những đánh giá bạn đã gửi.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        <i class="fas fa-star"></i>
        <strong>Chưa có đánh giá</strong>
        <p class="mb-0">Bạn chưa đánh giá kỹ thuật viên nào. Vui lòng hoàn thành yêu cầu sửa chữa và thanh toán để có thể đánh giá.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var request in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="section-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="mb-3">
                            <h5 class="card-title fw-bold text-primary">
                                <i class="fas fa-tools"></i> @request.DeviceType
                            </h5>
                            <p class="text-muted mb-0">@request.Issue</p>
                        </div>

                        <div class="mb-3 pb-3 border-bottom">
                            <b class="d-block mb-2">Đánh giá kỹ thuật viên:</b>
                            <div class="rating-display mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= request.TechnicianRating)
                                    {
                                        <i class="fas fa-star text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star text-secondary"></i>
                                    }
                                }
                                <span class="ms-2 fw-bold">@request.TechnicianRating/5</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <b class="d-block mb-2">Nhận xét:</b>
                            <p class="small text-secondary mb-0">@request.TechnicianRatingComment</p>
                        </div>

                        <div class="mt-auto">
                            <p class="small text-muted mb-0">
                                <b>Ngày đánh giá:</b><br />
                                @(request.TechnicianRatedAt.HasValue ? request.TechnicianRatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4">
    <a href="/Customer/Home" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại trang chủ
    </a>
</div>

<style>
    .rating-display {
        font-size: 1.3rem;
        letter-spacing: 0.3rem;
    }
</style>
