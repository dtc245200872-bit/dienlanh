@model List<dienlanh.Models.RepairRequest>

<div class="page-header">
    <div>
        <h2 class="page-title">Hủy yêu cầu</h2>
        <p class="page-subtitle">Hủy những yêu cầu chưa được xác nhận hoặc phân công.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        <i class="fas fa-info-circle"></i>
        <strong>Không có yêu cầu để hủy</strong>
        <p class="mb-0">Hiện tại không có yêu cầu nào đang ở trạng thái chờ xử lý hoặc đã phân công.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var request in Model.OrderByDescending(r => r.PreferredVisitAt))
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="section-card h-100 d-flex flex-column">
                    <div class="card-body d-flex flex-column h-100">
                        <h5 class="card-title fw-bold text-primary">
                            <i class="fas fa-tools"></i> @request.DeviceType
                        </h5>
                        <p class="text-muted mb-2">@request.Issue</p>
                        <p class="small text-secondary mb-2">@request.Address</p>
                        <p class="small text-secondary mb-2">
                            <b>Lịch hẹn mong muốn:</b>
                            @(request.PreferredVisitAt.HasValue ? request.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa chọn")
                        </p>
                        <div class="mb-3">
                            @if (request.Status == "Chờ xử lý")
                            {
                                <span class="badge bg-secondary">Chờ xử lý</span>
                            }
                            else if (request.Status == "Đã phân công")
                            {
                                <span class="badge bg-warning text-dark">Đã phân công</span>
                            }
                        </div>
                        <p class="small text-muted">
                            <b>Lịch hẹn:</b> @(request.PreferredVisitAt.HasValue ? request.PreferredVisitAt.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa chọn")
                        </p>
                        <form method="post" action="/Customer/CancelRequestConfirm" class="mt-auto">
                            <input type="hidden" name="id" value="@request.Id" />
                            <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Bạn có chắc chắn muốn hủy yêu cầu này?');">
                                <i class="fas fa-times-circle"></i> Hủy yêu cầu
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4">
    <a href="/Customer/Home" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại trang chủ
    </a>
</div>
