@model List<dienlanh.Models.RepairRequest>

<div class="page-header">
    <div>
        <h2 class="page-title">Lịch sử báo lỗi</h2>
        <p class="page-subtitle">Xem những lỗi bạn đã báo cáo cho hệ thống.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        <i class="fas fa-flag"></i>
        <strong>Chưa có báo lỗi</strong>
        <p class="mb-0">Bạn chưa báo cáo lỗi nào cho hệ thống.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var request in Model.OrderByDescending(r => r.ReportedAt))
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="section-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="mb-3">
                            <h5 class="card-title fw-bold text-primary">
                                <i class="fas fa-tools"></i> @request.DeviceType
                            </h5>
                            <p class="text-muted mb-0">@request.Issue</p>
                        </div>

                        <div class="mb-3">
                            @if (request.ReportResolved)
                            {
                                <span class="badge bg-success">Đã xử lý</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Chưa xử lý</span>
                            }
                        </div>

                        <div class="mb-3 pb-3 border-bottom">
                            <b class="d-block mb-2">Nội dung báo lỗi:</b>
                            <p class="small text-secondary mb-0">@request.CustomerReportNote</p>
                        </div>

                        @if (request.ReportResolved)
                        {
                            <div class="mb-3 p-2 bg-light rounded">
                                <b class="d-block mb-2 text-success">Trả lời từ hệ thống:</b>
                                <p class="small text-secondary mb-0">@request.ReportResolutionNote</p>
                            </div>
                        }

                        <div class="mt-auto">
                            <p class="small text-muted mb-1">
                                <b>Báo cáo ngày:</b><br />
                                @(request.ReportedAt.HasValue ? request.ReportedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                            </p>
                            @if (request.ResolvedAt.HasValue)
                            {
                                <p class="small text-muted mb-0">
                                    <b>Giải quyết ngày:</b><br />
                                    @request.ResolvedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4">
    <a href="/Customer/Home" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại trang chủ
    </a>
</div>
