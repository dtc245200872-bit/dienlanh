<div class="customer-home-header">
    <h1>Chào mừng khách hàng</h1>
    <p>Vui lòng chọn chức năng từ menu để tiếp tục.</p>
</div>

<section class="customer-hero" id="customerHero">
    <button type="button" class="customer-hamburger" id="customerMenuToggle" aria-label="Mở menu khách hàng">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <aside class="customer-drawer" id="customerDrawer">
        <a class="customer-menu-item" href="/Repair/Create">Tạo yêu cầu sửa chữa</a>
        <a class="customer-menu-item" href="/Customer/MyRequests">Yêu cầu của tôi</a>
        <a class="customer-menu-item" href="/Repair/History">Lịch sử sửa chữa</a>
        <a class="customer-menu-item" href="/Account/Profile">Thông tin tài khoản</a>
    </aside>
</section>

<script>
    (function () {
        const toggle = document.getElementById("customerMenuToggle");
        const drawer = document.getElementById("customerDrawer");
        if (!toggle || !drawer) return;

        toggle.addEventListener("click", function () {
            drawer.classList.toggle("open");
            toggle.classList.toggle("open");
        });
    })();
</script>