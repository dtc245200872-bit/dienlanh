@{
    ViewData["Title"] = "Hỗ trợ khách hàng";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Hỗ trợ & Liên hệ</h2>
        <p class="page-subtitle">Chúng tôi luôn sẵn sàng giúp đỡ bạn.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Support Channels -->
        <div class="section-card mb-4">
            <div class="card-body">
                <h5 class="mb-4">Kênh hỗ trợ</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="support-channel p-3 rounded border">
                            <i class="fas fa-phone text-primary mb-3" style="font-size: 1.8rem;"></i>
                            <h6 class="fw-bold">Gọi điện</h6>
                            <p class="text-muted small mb-2">Gọi trực tiếp cho đội hỗ trợ</p>
                            <a href="tel:+84123456789" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-phone"></i> 0123 456 789
                            </a>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="support-channel p-3 rounded border">
                            <i class="fas fa-envelope text-primary mb-3" style="font-size: 1.8rem;"></i>
                            <h6 class="fw-bold">Email</h6>
                            <p class="text-muted small mb-2">Gửi email cho chúng tôi</p>
                            <a href="mailto:support@dienlanh.com" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-envelope"></i> Email
                            </a>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="support-channel p-3 rounded border">
                            <i class="fas fa-comments text-primary mb-3" style="font-size: 1.8rem;"></i>
                            <h6 class="fw-bold">Chat</h6>
                            <p class="text-muted small mb-2">Trò chuyện với đội hỗ trợ</p>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#chatModal">
                                <i class="fas fa-comments"></i> Bắt đầu chat
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="support-channel p-3 rounded border">
                            <i class="fas fa-map-marker-alt text-primary mb-3" style="font-size: 1.8rem;"></i>
                            <h6 class="fw-bold">Địa chỉ</h6>
                            <p class="text-muted small mb-2">Ghé thăm chi nhánh của chúng tôi</p>
                            <a href="#" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#locationModal">
                                <i class="fas fa-map"></i> Xem địa chỉ
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- FAQ Section -->
        <div class="section-card mb-4">
            <div class="card-body">
                <h5 class="mb-4">Câu hỏi thường gặp</h5>
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                Làm thế nào để tạo yêu cầu sửa chữa?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Bạn có thể tạo yêu cầu mới bằng cách nhấp vào "Tạo yêu cầu sửa chữa" từ menu chính. Sau đó, cung cấp thông tin chi tiết về thiết bị, vấn đề và địa chỉ của bạn.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                Tôi có thể hủy yêu cầu không?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Có, bạn có thể hủy yêu cầu nếu nó chưa được xác nhận hoặc phân công cho kỹ thuật viên. Vào phần "Hủy yêu cầu" để thực hiện điều này.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                Thời gian phục vụ của bạn là bao lâu?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Thời gian phục vụ tùy thuộc vào vấn đề cụ thể. Thông thường, chúng tôi sẽ liên hệ với bạn trong vòng 2 giờ để xác nhận yêu cầu.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Bạn chấp nhận hình thức thanh toán nào?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Chúng tôi chấp nhận các hình thức thanh toán trực tuyến thông qua hệ thống của chúng tôi. Bạn sẽ nhận được thông báo khi yêu cầu hoàn thành để tiến hành thanh toán.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <div class="section-card mb-4">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Giờ làm việc</h6>
                <div class="small">
                    <p class="mb-1"><b>Thứ 2 - Thứ 6:</b> 8:00 AM - 6:00 PM</p>
                    <p class="mb-1"><b>Thứ 7:</b> 8:00 AM - 2:00 PM</p>
                    <p class="mb-0"><b>Chủ nhật:</b> Đóng cửa</p>
                </div>
            </div>
        </div>

        <div class="section-card">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Thông tin quan trọng</h6>
                <ul class="small list-unstyled">
                    <li class="mb-2">
                        <a href="#" class="text-decoration-none">
                            <i class="fas fa-file-alt"></i> Điều khoản dịch vụ
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-decoration-none">
                            <i class="fas fa-shield-alt"></i> Chính sách bảo mật
                        </a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-decoration-none">
                            <i class="fas fa-question-circle"></i> Chính sách hoàn tiền
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Chat Modal -->
<div class="modal fade" id="chatModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chat với hỗ trợ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">Tính năng chat sẽ sớm được cung cấp. Vui lòng liên hệ chúng tôi qua điện thoại hoặc email ngay bây giờ.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Location Modal -->
<div class="modal fade" id="locationModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Địa chỉ của chúng tôi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><b>Công ty Điện Lạnh DienLanh</b></p>
                <p>
                    <i class="fas fa-map-marker-alt"></i> 123 Đường ABC, Quận XYZ, TP. Hồ Chí Minh<br />
                    <i class="fas fa-phone"></i> <a href="tel:+84123456789">0123 456 789</a><br />
                    <i class="fas fa-envelope"></i> <a href="mailto:support@dienlanh.com">support@dienlanh.com</a>
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a href="/Customer/Home" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại trang chủ
    </a>
</div>

<style>
    .support-channel {
        transition: all 0.3s ease;
    }

    .support-channel:hover {
        background: #f8f9fa;
        border-color: #007bff !important;
    }
</style>
