<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DienLanh</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />

</head>

<body>
    @inject dienlanh.Data.AppDbContext Db
    @{
        var email = Context.Session.GetString("email");
        var role = Context.Session.GetString("role")?.ToLower(); // 🔥 FIX Ở ĐÂY
        var homeUrl = "/";
        if (role == "customer")
        {
            homeUrl = "/Customer/Home";
        }
        else if (role == "technician")
        {
            homeUrl = "/Repair/MyJobs";
        }
        else if (role == "admin")
        {
            homeUrl = "/Admin/Dashboard";
        }

        var unresolvedReportCount = 0;
        if (role == "admin")
        {
            unresolvedReportCount = Db.RepairRequests.Count(r => r.CustomerReported && !r.ReportResolved);
        }
    }

    <nav class="navbar navbar-expand-lg app-navbar shadow-sm">
        <div class="container">

            <a class="navbar-brand fw-bold" href="@homeUrl">DienLanh</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">

                <!-- MENU TRÁI -->
                <ul class="navbar-nav me-auto">

                    @* CUSTOMER: dùng menu trong trang khách hàng *@

                    @* TECHNICIAN *@
                    @if (role == "technician")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Repair/MyJobs">Công việc của tôi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Device/Index">Thiết bị</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Component/Index">Linh kiện</a>
                        </li>
                    }

                    @* ADMIN *@
                    @if (role == "admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Statistics">Thống kê</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Requests">Quản lý yêu cầu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Staff">Nhân viên</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Reports">
                                Báo lỗi khách hàng
                                @if (unresolvedReportCount > 0)
                                {
                                    <span class="badge bg-danger ms-1">@unresolvedReportCount</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Device/Index">Thiết bị</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Component/Index">Linh kiện</a>
                        </li>
                    }

                </ul>

                <!-- USER -->
                <ul class="navbar-nav">
                    @if (email != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                @email
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="/Account/Profile">Thông tin tài khoản</a>
                                </li>
                                <li class="dropdown-item text-muted">
                                    Vai trò: <b>@role</b>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <li>
                                    <a class="dropdown-item text-danger" href="/Account/Logout">
                                        Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light" href="/Account/Login">Đăng nhập</a>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>

    <!-- CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="text-center mt-5 p-3 border-top">
        © 2026 - Hệ thống sửa chữa điện lạnh
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>