<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DienLanh</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    @{
        var email = Context.Session.GetString("email");
        var role = Context.Session.GetString("role");
    }

    <!-- 🔥 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container">

            <a class="navbar-brand fw-bold" href="/">❄️ Điện lạnh</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">

                <!-- MENU TRÁI -->
                <ul class="navbar-nav me-auto">

                    @* CUSTOMER *@
                    @if (role == "Customer")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Repair/Create">Tạo yêu cầu</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Customer/MyRequests">Yêu cầu của tôi</a>
                        </li>
                    }

                    @* TECHNICIAN *@
                    @if (role == "Technician")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Repair/MyJobs">Công việc của tôi</a>
                        </li>
                    }

                    @* ADMIN *@
                    @if (role == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Dashboard">Dashboard</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Requests">Quản lý yêu cầu</a>
                        </li>
                    }

                </ul>

                <!-- USER -->
                <ul class="navbar-nav">
                    @if (email != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                👤 @email
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li class="dropdown-item text-muted">
                                    Vai trò: <b>@role</b>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <li>
                                    <a class="dropdown-item text-danger" href="/Account/Logout">
                                        Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light" href="/Account/Login">Đăng nhập</a>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>

    <!-- 🔥 CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- 🔥 FOOTER -->
    <footer class="text-center mt-5 p-3 border-top">
        © 2026 - Hệ thống sửa chữa điện lạnh
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>