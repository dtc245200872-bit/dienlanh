@model dienlanh.Models.User

@{
    ViewData["Title"] = "Chỉnh sửa thông tin tài khoản";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-user-edit"></i> Chỉnh sửa thông tin tài khoản
                    </h4>
                </div>

                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post" action="@Url.Action("Edit", "Account")">
                        <!-- Full Name -->
                        <div class="mb-3">
                            <label for="Name" class="form-label">
                                <i class="fas fa-user"></i> Họ và tên
                            </label>
                            <input type="text" class="form-control" id="Name" name="Name" 
                                   value="@Model.Name" placeholder="Nhập họ và tên của bạn">
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label for="Email" class="form-label">
                                <i class="fas fa-envelope"></i> Email
                            </label>
                            <input type="email" class="form-control" id="Email" name="Email" 
                                   value="@Model.Email" required placeholder="Nhập email của bạn">
                        </div>

                        <!-- Phone Number -->
                        <div class="mb-3">
                            <label for="Phone" class="form-label">
                                <i class="fas fa-phone"></i> Số điện thoại
                            </label>
                            <input type="tel" class="form-control" id="Phone" name="Phone" 
                                   value="@Model.Phone" placeholder="Nhập số điện thoại của bạn">
                        </div>

                        <!-- Address -->
                        <div class="mb-3">
                            <label for="Address" class="form-label">
                                <i class="fas fa-map-marker-alt"></i> Địa chỉ
                            </label>
                            <textarea class="form-control" id="Address" name="Address" rows="3" 
                                      placeholder="Nhập địa chỉ của bạn">@Model.Address</textarea>
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            <label for="Password" class="form-label">
                                <i class="fas fa-lock"></i> Mật khẩu mới
                            </label>
                            <input type="password" class="form-control" id="Password" name="Password" 
                                   placeholder="Để trống nếu không đổi mật khẩu">
                            <small class="text-muted d-block mt-1">
                                <i class="fas fa-info-circle"></i> Chỉ nhập nếu bạn muốn đổi mật khẩu
                            </small>
                        </div>

                        <hr>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("Profile", "Account")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
