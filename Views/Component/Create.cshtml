@model dienlanh.Models.Component
@using dienlanh.Models
@{
    var devices = ViewBag.Devices as List<Device> ?? new List<Device>();
}

<h2 class="mb-3">Thêm linh kiện</h2>

<form method="post" class="card p-4 shadow-sm">
    <div class="mb-3">
        <label class="form-label">Tên linh kiện</label>
        <input class="form-control" name="Name" value="@Model?.Name" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Thiết bị liên quan</label>
        <select class="form-select" name="DeviceId">
            <option value="">-- Chọn thiết bị --</option>
            @foreach (var d in devices)
            {
                <option value="@d.Id">@d.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Giá</label>
        <input type="number" min="0" step="1000" class="form-control" name="Price" value="@(Model?.Price ?? 0)" required />
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-success">Lưu</button>
        <a class="btn btn-outline-secondary" href="/Component/Index">Quay lại</a>
    </div>
</form>
